  print('Puntos marcados para ir a campo:', numPuntos);

  if (numPuntos > 0) {
    var listaPuntos = puntos.toList(numPuntos);
    
    // Iteramos sobre una secuencia de números [0, 1, 2...] en lugar de los objetos
    var indices = ee.List.sequence(0, ee.Number(numPuntos).subtract(1));
    
    var extraerCoordenadas = indices.map(function(index) {
      var p = ee.Feature(listaPuntos.get(index));
      var coordenadas = p.geometry().coordinates();
      
      return p.set({
        'ID_GPS': ee.String('Punto_').cat(ee.Number(index).add(1).format('%d')),
        'fecha_referencia': FECHA_MANUAL,
        'longitude': ee.Number(coordenadas.get(0)),
        'latitude': ee.Number(coordenadas.get(1))
      });
    });
    
    var puntosFinal = ee.FeatureCollection(extraerCoordenadas);

    print('Coordenadas capturadas:', puntosFinal);

    Export.table.toDrive({
      collection: puntosFinal,
      description: 'Puntos_GPS_Campo_' + FECHA_MANUAL.replace(/-/g, ''),
      folder: 'GEE_exports',
      fileFormat: 'CSV',
      selectors: ['ID_GPS', 'fecha_referencia', 'longitude', 'latitude']
    });
    
    Export.table.toDrive({
      collection: puntosFinal,
      description: 'Puntos_GPS_KML_' + FECHA_MANUAL.replace(/-/g, ''),
      folder: 'GEE_exports',
      fileFormat: 'KML'
    });

    print('✅ Exportación iniciada.');
  } else {
    print('ℹ️ La capa "puntosDibujados" está vacía.');
  }
} catch (e) {
  print('ℹ️ Dibuja puntos en el mapa usando la herramienta 📍 y nombra la capa como "puntosDibujados".');
}
